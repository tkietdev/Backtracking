#include <stdio.h>

int n;
int a[100];
int cnt = 0;
// ham ktra
int ktra() {
  for (int i = 3; i <= n; i++) {
    if (a[i] == 1 && a[i - 1] == 1 && a[i - 2] == 1)
      return 0;
  }
  return 1;
}
void In() {
  cnt++;
  printf("So thu nhat %d: ", cnt);
  for (int i = 1; i <= n; i++) {
    printf("%d", a[i]);
  }
  printf("\n");
}
// backtranking
void Try(int i) {
  for (int j = 0; j <= 1; j++) {
    a[i] = j;
    if (i == 1) {
      if (ktra())
        In();
    } else {
      Try(i - 1);
    }
  }
}
int main() {
  scanf("%d", &n);
  Try(n);
  return 0;
}